{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "Dockerfile",
      "nginx.conf",
      "docker-compose.yml"
    ],
    "rewrites": [
      { "source": "/dashboard", "destination": "/index.html" },
      { "source": "**", "destination": "/landing.html" }
    ]
  }
}
